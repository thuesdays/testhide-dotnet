# Copy this file to .env.local (which is gitignored) and fill in real values.
# Consumed by publish.bat. KEY=VALUE, one per line; lines starting with # are ignored.

# NuGet API key — create at https://www.nuget.org/account/apikeys
# Needs push scope for Testhide.Reporting.* package IDs (use a glob: Testhide.Reporting.*).
NUGET_API_KEY=oy2XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
